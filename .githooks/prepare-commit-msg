#!/usr/bin/env sh
# Re-attribute AI-assisted commits to the morgana-coding-agent bot. The assistant
# tool marks its work with a Claude co-author trailer; this swaps that trailer for
# the bot. A purely human commit has no such trailer and is left untouched. GitHub
# matches co-authors by the no-reply email below. Enabled by
# `git config core.hooksPath .githooks` (set by `just init`). See docs/ai-coding.md.
msg="$1"
bot='Co-authored-by: morgana-coding-agent[bot] <305433938+morgana-coding-agent[bot]@users.noreply.github.com>'

# No assistant trailer means a human commit -- nothing to re-attribute.
grep -qi '^Co-authored-by: Claude' "$msg" || exit 0

# Swap the Claude co-author line(s) for the bot, in place, without duplicating it.
awk -v bot="$bot" '
  tolower($0) ~ /^co-authored-by: claude/ { if (!done) { print bot; done = 1 } next }
  { print }
' "$msg" > "$msg.tmp" && mv "$msg.tmp" "$msg"
