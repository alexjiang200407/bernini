{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "windows",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "PLATFORM": "WINDOWS"
      }
    },
    {
      "name": "vs2022",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "toolset": "v143"
    },
    {
      "name": "vs2026",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "toolset": "v145"
    },
    {
      "name": "dx11",
      "hidden": true,
      "cacheVariables": {
        "RENDERER_BACKEND": "DX11",
        "NVRHI_WITH_DX11": "ON"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_CXX_FLAGS": "/EHsc /MP /external:W0",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG /EHsc /external:W0"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "windows-vs2022-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "binaryDir": "${sourceDir}/build/msvc-debug",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2022",
        "msvc",
        "dx11",
        "debug"
      ]
    },
    {
      "name": "windows-vs2022-msvc-release",
      "displayName": "Windows MSVC Release",
      "binaryDir": "${sourceDir}/build/msvc-release",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2022",
        "msvc",
        "dx11",
        "release"
      ]
    },
    {
      "name": "windows-vs2026-msvc-debug",
      "displayName": "Windows MSVC Debug VS2026",
      "binaryDir": "${sourceDir}/build/msvc-debug",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2026",
        "msvc",
        "dx11",
        "debug"
      ]
    },
    {
      "name": "windows-vs2026-msvc-release",
      "displayName": "Windows MSVC Release VS2026",
      "binaryDir": "${sourceDir}/build/msvc-release",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2026",
        "msvc",
        "dx11",
        "release"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-msvc-release",
      "configurePreset": "windows-vs2022-msvc-release",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2022-msvc-debug",
      "configurePreset": "windows-vs2022-msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-vs2026-msvc-release",
      "configurePreset": "windows-vs2026-msvc-release",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2026-msvc-debug",
      "configurePreset": "windows-vs2026-msvc-debug",
      "configuration": "Debug"
    }
  ]
}
