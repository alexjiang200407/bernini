{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "windows",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "PLATFORM": "WINDOWS"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "macos",
      "hidden": true,
      "cacheVariables": {
        "PLATFORM": "MACOS"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ninja",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "ninja"
      }
    },
    {
      "name": "vs2022",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "toolset": "v143",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "MSBUILD"
      }
    },
    {
      "name": "vs2026",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "toolset": "v145",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "MSBUILD"
      }
    },
    {
      "name": "clang",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "ninja",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "dx12",
      "hidden": true,
      "cacheVariables": {
        "RENDERER_BACKEND": "DX12",
        "NVRHI_WITH_DX12": "ON"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "CMAKE_CXX_FLAGS": "/EHsc /MP /external:W0",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /DNDEBUG /external:W0"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "BUILD_TESTS": "ON",
        "BERNINI_BUILD_EXAMPLES": "ON",
        "IS_DEBUG": "ON"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "BUILD_TESTS": "OFF",
        "BERNINI_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "windows-vs2022-msvc-dx12-debug",
      "displayName": "Windows MSVC Debug VS2022 - DirectX 12",
      "binaryDir": "${sourceDir}/build/vs2022-debug",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2022",
        "msvc",
        "dx12",
        "debug"
      ]
    },
    {
      "name": "windows-vs2022-msvc-dx12-release",
      "displayName": "Windows MSVC Release VS2022 - DirectX 12",
      "binaryDir": "${sourceDir}/build/vs2022-release",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2022",
        "msvc",
        "dx12",
        "release"
      ]
    },
    {
      "name": "windows-vs2026-msvc-dx12-debug",
      "displayName": "Windows MSVC Debug VS2026 - DirectX 12",
      "binaryDir": "${sourceDir}/build/vs2026-debug",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2026",
        "msvc",
        "dx12",
        "debug"
      ]
    },
    {
      "name": "windows-vs2026-msvc-dx12-release",
      "displayName": "Windows MSVC Release VS2026 - DirectX 12",
      "binaryDir": "${sourceDir}/build/vs2026-release",
      "inherits": [
        "vcpkg",
        "windows",
        "vs2026",
        "msvc",
        "dx12",
        "release"
      ]
    },
    {
      "name": "windows-ninja-msvc-dx12-debug",
      "displayName": "Windows MSVC Debug ninja - DirectX 12",
      "binaryDir": "${sourceDir}/build/ninja-msvc-debug",
      "inherits": [
        "vcpkg",
        "windows",
        "ninja",
        "msvc",
        "dx12",
        "debug"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-ninja-msvc-dx12-release",
      "displayName": "Windows MSVC Release ninja - DirectX 12",
      "binaryDir": "${sourceDir}/build/ninja-msvc-release",
      "inherits": [
        "vcpkg",
        "windows",
        "ninja",
        "msvc",
        "dx12",
        "release"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-clang-dx12-debug",
      "displayName": "Windows Clang Debug ninja - DirectX 12",
      "binaryDir": "${sourceDir}/build/ninja-clang-debug",
      "inherits": [
        "vcpkg",
        "windows",
        "clang",
        "dx12",
        "debug"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-clang-dx12-release",
      "displayName": "Windows Clang Release ninja - DirectX 12",
      "binaryDir": "${sourceDir}/build/ninja-clang-release",
      "inherits": [
        "vcpkg",
        "windows",
        "clang",
        "dx12",
        "release"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-clang-debug",
      "displayName": "macOS Clang Debug ninja - no renderer backend yet",
      "binaryDir": "${sourceDir}/build/macos-clang-debug",
      "inherits": [
        "vcpkg",
        "macos",
        "clang",
        "debug"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-clang-release",
      "displayName": "macOS Clang Release ninja - no renderer backend yet",
      "binaryDir": "${sourceDir}/build/macos-clang-release",
      "inherits": [
        "vcpkg",
        "macos",
        "clang",
        "release"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }

  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-msvc-dx12-release",
      "configurePreset": "windows-vs2022-msvc-dx12-release",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2022-msvc-dx12-debug",
      "configurePreset": "windows-vs2022-msvc-dx12-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-vs2026-msvc-dx12-release",
      "configurePreset": "windows-vs2026-msvc-dx12-release",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2026-msvc-dx12-debug",
      "configurePreset": "windows-vs2026-msvc-dx12-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-ninja-msvc-dx12-release",
      "configurePreset": "windows-ninja-msvc-dx12-release",
      "configuration": "Release"
    },
    {
      "name": "windows-ninja-msvc-dx12-debug",
      "configurePreset": "windows-ninja-msvc-dx12-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-clang-dx12-debug",
      "configurePreset": "windows-clang-dx12-debug"
    },
    {
      "name": "windows-clang-dx12-release",
      "configurePreset": "windows-clang-dx12-release"
    },
    {
      "name": "macos-clang-debug",
      "configurePreset": "macos-clang-debug"
    },
    {
      "name": "macos-clang-release",
      "configurePreset": "macos-clang-release"
    }
  ]
}
